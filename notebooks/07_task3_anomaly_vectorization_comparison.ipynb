    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"128946645838aa47\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Anomaly Vectorization Comparison\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook compares two anomaly feature spaces:\\n\",\n",
    "    \"\\n\",\n",
    "    \"- Sparse character TF-IDF\\n\",\n",
    "    \"- Dense TF-IDF + LSA\\n\",\n",
    "    \"\\n\",\n",
    "    \"Goal:\\n\",\n",
    "    \"\\n\",\n",
    "    \"- Check if LSA helps anomaly ranking quality and stability.\\n\",\n",
    "    \"- Compare overlap between top anomaly sets.\\n\",\n",
    "    \"- Export side-by-side diagnostics for report discussion.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Reader guide:\\n\",\n",
    "    \"\\n\",\n",
    "    \"- Both models use the same normalized input text.\\n\",\n",
    "    \"- Only the vector representation changes.\\n\",\n",
    "    \"- Ranking outputs are saved to `data/results/`.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"7e78d28aa5a272e4\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-09T19:35:20.180751700Z\",\n",
    "     \"start_time\": \"2026-04-09T19:35:19.912548800Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"from data_mining_assignment.core.data_io import ArticleDataset\\n\",\n",
    "    \"from data_mining_assignment.tasks.anomaly_detection import TextAnomalyDetector\\n\",\n",
    "    \"from data_mining_assignment.tasks.exploration import build_anomaly_candidate_table\\n\",\n",
    "    \"from data_mining_assignment.tasks.preprocessing import TextNormalizer, TextPreprocessor\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 1\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"d16f82bb8bffc873\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": \"## Load and normalize data\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"8d7ff7e979beb885\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-09T19:35:32.091047400Z\",\n",
    "     \"start_time\": \"2026-04-09T19:35:20.182752400Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"project_root_path = Path.cwd().parent\\n\",\n",
    "    \"results_data_directory_path = project_root_path / \\\"data\\\" / \\\"results\\\"\\n\",\n",
    "    \"results_data_directory_path.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"articles_csv_path = project_root_path / \\\"data\\\" / \\\"raw\\\" / \\\"articles.csv\\\"\\n\",\n",
    "    \"articles_data_frame = ArticleDataset(input_csv_path=articles_csv_path).load_articles()\\n\",\n",
    "    \"\\n\",\n",
    "    \"document_ids = articles_data_frame[\\\"doc_id\\\"].tolist()\\n\",\n",
    "    \"raw_texts = articles_data_frame[\\\"text\\\"].tolist()\\n\",\n",
    "    \"normalized_bundle = TextNormalizer().normalize_for_both_tasks(raw_texts)\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"98ade94f99f08731\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": \"## Model A: Sparse TF-IDF (char n-grams)\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"52bbd0c34fd5fc6b\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-09T19:35:33.739148700Z\",\n",
    "     \"start_time\": \"2026-04-09T19:35:32.139813600Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"sparse_preprocessor = TextPreprocessor(\\n\",\n",
    "    \"    vectorization_model_name=\\\"tfidf\\\",\\n\",\n",
    "    \"    max_features=30000,\\n\",\n",
    "    \"    min_document_frequency=1,\\n\",\n",
    "    \"    max_document_frequency=1.0,\\n\",\n",
    "    \"    ngram_range=(3, 5),\\n\",\n",
    "    \"    analyzer_mode=\\\"char_wb\\\",\\n\",\n",
    "    \")\\n\",\n",
    "    \"sparse_features = sparse_preprocessor.fit_transform(normalized_bundle.anomaly_texts)\\n\",\n",
    "    \"\\n\",\n",
    "    \"sparse_detector = TextAnomalyDetector(contamination_ratio=0.02, random_seed=42)\\n\",\n",
    "    \"sparse_mask, sparse_scores = sparse_detector.run_detection(sparse_features)\\n\",\n",
    "    \"\\n\",\n",
    "    \"sparse_table = build_anomaly_candidate_table(\\n\",\n",
    "    \"    document_ids=document_ids,\\n\",\n",
    "    \"    anomaly_scores=sparse_scores.tolist(),\\n\",\n",
    "    \"    anomaly_mask=sparse_mask.tolist(),\\n\",\n",
    "    \")\\n\",\n",
    "    \"sparse_table.to_csv(results_data_directory_path / \\\"notebook_04_sparse_anomaly_candidates.csv\\\", index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"sparse_table.head(20)\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 3\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"fe96f5cb15a95afa\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": \"## Model B: Dense TF-IDF + LSA\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"a0dc36df402be8f\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-09T19:35:47.404013Z\",\n",
    "     \"start_time\": \"2026-04-09T19:35:33.782957200Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"lsa_preprocessor = TextPreprocessor(\\n\",\n",
    "    \"    vectorization_model_name=\\\"tfidf_lsa_dense\\\",\\n\",\n",
    "    \"    max_features=30000,\\n\",\n",
    "    \"    min_document_frequency=1,\\n\",\n",
    "    \"    max_document_frequency=1.0,\\n\",\n",
    "    \"    ngram_range=(3, 5),\\n\",\n",
    "    \"    analyzer_mode=\\\"char_wb\\\",\\n\",\n",
    "    \"    dense_embedding_dimension=256,\\n\",\n",
    "    \"    random_seed=42,\\n\",\n",
    "    \")\\n\",\n",
    "    \"lsa_features = lsa_preprocessor.fit_transform(normalized_bundle.anomaly_texts)\\n\",\n",
    "    \"\\n\",\n",
    "    \"lsa_detector = TextAnomalyDetector(contamination_ratio=0.02, random_seed=42)\\n\",\n",
    "    \"lsa_mask, lsa_scores = lsa_detector.run_detection(lsa_features)\\n\",\n",
    "    \"\\n\",\n",
    "    \"lsa_table = build_anomaly_candidate_table(\\n\",\n",
    "    \"    document_ids=document_ids,\\n\",\n",
    "    \"    anomaly_scores=lsa_scores.tolist(),\\n\",\n",
    "    \"    anomaly_mask=lsa_mask.tolist(),\\n\",\n",
    "    \")\\n\",\n",
    "    \"lsa_table.to_csv(results_data_directory_path / \\\"notebook_04_lsa_anomaly_candidates.csv\\\", index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"lsa_table.head(20)\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 4\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"b67b5a5e1e8d4d52\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": \"## Compare top anomalies (top-20 side by side)\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"127450880ec5e195\",\n",

    "   \"source\": [\n",
    "    \"def compute_top_k_overlap(\\n\",\n",
    "    \"    sparse_ranked_table: pd.DataFrame,\\n\",\n",
    "    \"    lsa_ranked_table: pd.DataFrame,\\n\",\n",
    "    \"    top_k: int,\\n\",\n",
    "    \") -> int:\\n\",\n",
    "    \"    \\\"\\\"\\\"Computes overlap between two ranked top-k anomaly sets.\\\"\\\"\\\"\\n\",\n",
    "    \"    sparse_top_ids = set(sparse_ranked_table.head(top_k)[\\\"doc_id\\\"].tolist())\\n\",\n",
    "    \"    lsa_top_ids = set(lsa_ranked_table.head(top_k)[\\\"doc_id\\\"].tolist())\\n\",\n",
    "    \"    return len(sparse_top_ids.intersection(lsa_top_ids))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"overlap_diagnostics = pd.DataFrame(\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"top_k\\\": [10, 25, 50, 75, 100],\\n\",\n",
    "    \"        \\\"overlap_count\\\": [\\n\",\n",
    "    \"            compute_top_k_overlap(sparse_table, lsa_table, top_k_value) for top_k_value in [10, 25, 50, 75, 100]\\n\",\n",
    "    \"        ],\\n\",\n",
    "    \"    }\\n\",\n",
    "    \")\\n\",\n",
    "    \"overlap_diagnostics.to_csv(results_data_directory_path / \\\"notebook_04_overlap_diagnostics.csv\\\", index=False)\\n\",\n",
    "    \"overlap_diagnostics\"\n",
